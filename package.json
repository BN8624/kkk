{
  "name": "three-crowns-island",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src tests",
    "simulate": "vite-node scripts/simulate.ts",
    "determinism": "vite-node scripts/determinism.ts",
    "package:itch": "node scripts/package-itch.mjs",
    "simulate:campaign": "vite-node scripts/campaign-sim.ts",
    "simulate:matrix": "vite-node scripts/campaign-matrix.ts",
    "simulate:official": "vite-node scripts/official-sim.ts",
    "test:scenario": "vitest run tests/scenario-document.test.ts tests/campaign.test.ts",
    "build:test": "tsc --noEmit && vite build --outDir dist-test --mode testbridge",
    "test:e2e:dist": "playwright test -c playwright.dist.config.ts"
  },
  "dependencies": {
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.7",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
